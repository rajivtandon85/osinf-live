{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "osinf.live"
        }
      ],
      "destination": "https://www.osinf.live/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/feeds/refresh",
      "schedule": "0 6 * * *"
    }
  ]
}
